{
  "name": "coleman4hcs",
  "image": "mcr.microsoft.com/devcontainers/python:3",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | bash && export PATH=\"$HOME/.local/bin:$PATH\" && uv sync --extra dev --extra docs --extra notebook && uv run pre-commit install --hook-type pre-commit --hook-type commit-msg --hook-type pre-push",
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "astral-sh.ruff",
        "GitHub.copilot",
        "tamasfe.even-better-toml",
        "yzhang.markdown-all-in-one",
        "ms-pyright.pyright",
        "ms-toolsai.jupyter",
        "astral-sh.ty",
        "marimo-team.vscode-marimo"
      ],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        }
      }
    }
  }
}
