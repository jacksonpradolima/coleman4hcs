{
  "name": "coleman4hcs",
  "image": "mcr.microsoft.com/devcontainers/python:3",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "forwardPorts": [
    3000,
    4317,
    4318,
    8123,
    8889,
    9000
  ],
  "portsAttributes": {
    "3000": { "label": "Grafana", "onAutoForward": "notify" },
    "4317": { "label": "OTel Collector (gRPC)", "onAutoForward": "silent" },
    "4318": { "label": "OTel Collector (HTTP)", "onAutoForward": "silent" },
    "8123": { "label": "ClickHouse (HTTP)", "onAutoForward": "silent" },
    "8889": { "label": "Prometheus metrics", "onAutoForward": "silent" },
    "9000": { "label": "ClickHouse (native)", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "astral-sh.ruff",
        "GitHub.copilot",
        "tamasfe.even-better-toml",
        "yzhang.markdown-all-in-one",
        "ms-pyright.pyright",
        "ms-toolsai.jupyter",
        "astral-sh.ty",
        "marimo-team.vscode-marimo",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [],
        "ruff.enable": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        }
      }
    }
  }
}
